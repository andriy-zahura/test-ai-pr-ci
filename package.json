{
  "name": "jti-ai-review",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local AI pre-commit review pipeline with doc-sync skill",
  "scripts": {
    "build": "npm run build:cli",
    "build:cli": "tsc -p cli/tsconfig.json",
    "ai-review": "node dist-cli/cli.js run --provider mock",
    "ai-review:init": "node dist-cli/cli.js init",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "commander": "^13.1.0",
    "husky": "^9.1.7",
    "simple-git": "^3.27.0",
    "typescript": "^5.7.3"
  }
}
