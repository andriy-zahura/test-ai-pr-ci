{
  "name": "jti-ai-review",
  "version": "0.1.0",
  "description": "Local AI pre-commit review pipeline with doc-sync skill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andriy-zahura/test-ai-pr-ci.git"
  },
  "homepage": "https://github.com/andriy-zahura/test-ai-pr-ci#readme",
  "bugs": {
    "url": "https://github.com/andriy-zahura/test-ai-pr-ci/issues"
  },
  "keywords": [
    "ai",
    "code-review",
    "pre-commit",
    "husky",
    "cursor",
    "llm"
  ],
  "type": "module",
  "bin": {
    "ai-review": "dist-cli/cli.js"
  },
  "files": [
    "dist-cli",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run build:cli",
    "build:cli": "tsc -p cli/tsconfig.json && mkdir -p dist-cli/prompt && cp cli/src/prompt/systemPrompt.md dist-cli/prompt/",
    "pack:local": "npm run build:cli && npm pack",
    "prepack": "npm run build:cli",
    "ai-review": "node dist-cli/cli.js run",
    "ai-review:init": "node dist-cli/cli.js init",
    "prepare": "test -d .husky && husky || true"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "husky": "^9.1.7",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
